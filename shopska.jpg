<!doctype html>
<html xmlns:th="http://www.thymeleaf.org">
<body>
<nav th:fragment="nav" class="site-nav">
    <a class="brand" href="/">🍽 Recipe Book</a>
    <button class="nav-toggle" type="button" aria-label="Menu">☰</button>
    <div class="nav-links">
        <a href="/">Home</a>
        <a th:if="${currentUser.loggedIn}" href="/recipes">Recipes</a>
        <a th:if="${currentUser.loggedIn}" href="/recipes/create">Create</a>
        <a th:if="${currentUser.loggedIn}" href="/recipes/my">My Recipes</a>
        <a th:if="${currentUser.loggedIn}" href="/favorites">Favorites</a>
        <a th:if="${currentUser.loggedIn and currentUser.admin}" href="/admin">Admin</a>
        <a th:unless="${currentUser.loggedIn}" href="/login">Login</a>
        <a th:unless="${currentUser.loggedIn}" class="nav-cta" href="/register">Register</a>
        <span class="user-pill" th:if="${currentUser.loggedIn}" th:text="'Hello, ' + ${currentUser.username}"></span>
        <form th:if="${currentUser.loggedIn}" class="inline" method="post" action="/logout"><button class="ghost-btn">Logout</button></form>
    </div>
</nav>
<footer th:fragment="footer" class="site-footer">
    <p>Recipe Book • домашни рецепти, снимки и любими ястия</p>
</footer>
</body>
</html>
